# Production environment variables for the Vespin VPS deployment.
#
# Copy this file to `.env` on the VPS (at /home/deploy/vespin/.env) and fill in
# real values. NEVER commit the real .env — only this template.
#
# After editing on the VPS:
#   chmod 600 .env
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# ---

# --- Domain / TLS -------------------------------------------------------------

# Public domain for the API. DuckDNS subdomain works (e.g., vespin-api.duckdns.org).
DOMAIN=vespin-api.duckdns.org

# Email for Let's Encrypt expiry notices. Use a real address you check.
ACME_EMAIL=you@example.com

# --- Container registry -------------------------------------------------------

# GitHub organization or username that owns the GHCR images.
# Images expected at: ghcr.io/${GHCR_OWNER}/vespin-api and /vespin-migrate
GHCR_OWNER=your-github-handle

# Image tag to deploy. Default 'latest' is fine; CI may set a specific SHA tag.
IMAGE_TAG=latest

# --- Database -----------------------------------------------------------------

# Postgres password for the `vespin` user. Generate with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-strong-random-secret

# --- Application secrets ------------------------------------------------------

# JWT signing secret. MUST be a strong random string, MUST NOT be reused
# across environments. Generate with:
#   openssl rand -base64 64
JWT_SECRET=change-me-to-a-strong-random-secret
